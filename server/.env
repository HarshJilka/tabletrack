PORT=3001

# Local PostgreSQL (pgAdmin password you set during install)
DATABASE_URL=postgresql://postgres:3401@localhost:5432/tabletrack

# Change both secrets before deploying to production
JWT_SECRET=tabletrack-jwt-secret-dev-only
QR_ROTATION_SECRET=tabletrack-qr-secret-dev-only

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173
